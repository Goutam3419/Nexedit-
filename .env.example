# ============================================
# AI Design Platform — Environment Variables
# ============================================
# Yeh file sirf TEMPLATE hai — ismein koi real key nahi honi chahiye.
#
# Kaise use karein:
# 1. Is file ka naam ".env" kar dein (isi folder me, root me)
# 2. Neeche har line me apni asli values daal dein
# 3. .env file kabhi bhi GitHub/chat/kahin bhi share na karein
# 4. npm run dev restart karein
#
# .gitignore me ".env" already add hai (real project me commit hone se bachega)

# ---------- Firebase (Step 8-9 ke liye zaroori) ----------
# https://console.firebase.google.com se naya project banayein
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ---------- Background Removal (Step 10, optional) ----------
# https://www.remove.bg/api — free tier available
VITE_REMOVE_BG_API_KEY=

# ---------- Magic Eraser (Step 10, optional) ----------
# https://clipdrop.co/apis — free tier available
VITE_CLIPDROP_API_KEY=

# ---------- AI Image / AI Logo / AI Writer (Step 11, optional) ----------
# https://platform.openai.com/api-keys — paid (pay-as-you-go)
VITE_OPENAI_API_KEY=

# ---------- Admin Panel access (Step 13) ----------
# Comma-separated emails jo /admin page access kar sakte hain
VITE_ADMIN_EMAILS=
